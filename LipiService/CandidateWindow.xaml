<Window x:Class="LipiService.CandidateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lipi Candidate Window" Height="250" Width="220"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowActivated="False" Focusable="False" ShowInTaskbar="False">
    <Grid Margin="10">
        <Border Background="#202020" CornerRadius="8" BorderBrush="#3A3A3A" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="12" ShadowDepth="4" Opacity="0.6"/>
            </Border.Effect>
            
            <ItemsControl x:Name="SuggestionsList" Margin="0,5,0,5">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="15,8" Background="{Binding BackgroundBrush}" CornerRadius="4" Margin="5,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding IndexText}" Foreground="#AAAAAA" FontSize="14" FontFamily="Segoe UI" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Word}" Foreground="{Binding ForegroundBrush}" FontSize="18" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</Window>
