<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="LipiDashboard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LipiDashboard"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="LipiDashboard">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <NavigationView x:Name="NavView" PaneDisplayMode="Left" IsBackButtonVisible="Collapsed" SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Setting" Content="General" Tag="General" />
                <NavigationViewItem Icon="Help" Content="About" Tag="About" />
            </NavigationView.MenuItems>

            <Grid Padding="24">
                <!-- General Panel -->
                <StackPanel x:Name="GeneralPanel" Spacing="20">
                    <TextBlock Text="General" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20"/>
                    <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Online Suggestions (Google API)" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <TextBlock Text="Fetch transliteration suggestions from Google Input Tools API" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch x:Name="OnlineModeSwitch" Grid.Column="1" Toggled="OnlineModeSwitch_Toggled" />
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- Settings Panel -->
                <StackPanel x:Name="SettingsPanel" Spacing="20" Visibility="Collapsed">
                    <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20"/>
                    
                    <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Offline Cache" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <TextBlock Text="Save suggestions locally and fallback to offline mode when API is unavailable" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch x:Name="OfflineModeSwitch" Grid.Column="1" Toggled="OfflineModeSwitch_Toggled" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Clear Offline Cache" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <TextBlock Text="Deletes all learned words and cached suggestions from memory and disk" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Button x:Name="ClearCacheButton" Content="Clear Cache" Grid.Column="1" Click="ClearCacheButton_Click" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- About Panel -->
                <StackPanel x:Name="AboutPanel" Spacing="20" Visibility="Collapsed">
                    <TextBlock Text="About" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20"/>
                    <TextBlock Text="Lipi IME - Open Source Transliteration Engine" Style="{ThemeResource BodyTextBlockStyle}"/>
                </StackPanel>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
