<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="LipiDashboard.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:LipiDashboard"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="LipiDashboard">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <NavigationView x:Name="NavView" PaneDisplayMode="Left" IsBackButtonVisible="Collapsed" SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Icon="Home" Content="General" Tag="General" />
                <NavigationViewItem Icon="Library" Content="Custom Dictionary" Tag="CustomDictionary" />
                <NavigationViewItem Icon="Document" Content="Typing Rules" Tag="TypingRules" />
                <NavigationViewItem Icon="Edit" Content="Suggestion UI" Tag="SuggestionUI" />
                <NavigationViewItem Icon="Help" Content="About" Tag="About" />
            </NavigationView.MenuItems>

            <Grid Padding="24">
                <!-- General Panel -->
                <StackPanel x:Name="GeneralPanel" Spacing="20">
                    <TextBlock Text="General" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20"/>
                    <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Online Suggestions (Google API)" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <TextBlock Text="Fetch transliteration suggestions from Google Input Tools API" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch x:Name="OnlineModeSwitch" Grid.Column="1" Toggled="OnlineModeSwitch_Toggled" />
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- Typing Rules Panel -->
                <StackPanel x:Name="TypingRulesPanel" Spacing="20" Visibility="Collapsed">
                    <TextBlock Text="Typing Rules" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20"/>
                    <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Disable IME in Web Pages (Website Bypass)" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <TextBlock Text="Automatically bypass typing in browser web pages (search bar still works)" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch x:Name="BrowserBypassSwitch" Grid.Column="1" Toggled="BrowserBypassSwitch_Toggled" />
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- Custom Dictionary Panel -->
                <Grid x:Name="CustomDictionaryPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Custom Dictionary" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20"/>
                    
                    <!-- Add new word -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
                        <TextBox x:Name="DictEnglishInput" PlaceholderText="English Word (e.g. ami)" Width="200"/>
                        <TextBox x:Name="DictBengaliInput" PlaceholderText="Bengali Translation (e.g. আমি)" Width="200"/>
                        <Button x:Name="AddDictWordButton" Content="Add Word" Click="AddDictWordButton_Click" Style="{ThemeResource AccentButtonStyle}"/>
                    </StackPanel>
                    
                    <!-- List of words -->
                    <ListView x:Name="DictionaryListView" Grid.Row="2" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding EnglishWord}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding BengaliWord}" VerticalAlignment="Center"/>
                                    <Button Grid.Column="2" Content="Delete" Tag="{Binding EnglishWord}" Click="DeleteDictWordButton_Click" Style="{ThemeResource DefaultButtonStyle}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

                <!-- Settings Panel -->
                <StackPanel x:Name="SettingsPanel" Spacing="20" Visibility="Collapsed">
                    <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20"/>
                    
                    <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Offline Cache" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <TextBlock Text="Save suggestions locally and fallback to offline mode when API is unavailable" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <ToggleSwitch x:Name="OfflineModeSwitch" Grid.Column="1" Toggled="OfflineModeSwitch_Toggled" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Clear Offline Cache" Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <TextBlock Text="Deletes all learned words and cached suggestions from memory and disk" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <Button x:Name="ClearCacheButton" Content="Clear Cache" Grid.Column="1" Click="ClearCacheButton_Click" VerticalAlignment="Center" />
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- Suggestion UI Panel -->
                <StackPanel x:Name="SuggestionUIPanel" Spacing="20" Visibility="Collapsed">
                    <TextBlock Text="Suggestion UI Customization" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20"/>
                    <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="16" CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Spacing="15">
                        
                        <!-- Colors -->
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Window Background Color" VerticalAlignment="Center"/>
                            <DropDownButton Grid.Column="1" Content="Pick Color">
                                <DropDownButton.Flyout>
                                    <Flyout><ColorPicker x:Name="SugBgColorPicker" ColorChanged="SugUI_ColorPickerChanged" IsAlphaEnabled="False"/></Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Text Color" VerticalAlignment="Center"/>
                            <DropDownButton Grid.Column="1" Content="Pick Color">
                                <DropDownButton.Flyout>
                                    <Flyout><ColorPicker x:Name="SugTextColorPicker" ColorChanged="SugUI_ColorPickerChanged" IsAlphaEnabled="False"/></Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Selected Item Background Color" VerticalAlignment="Center"/>
                            <DropDownButton Grid.Column="1" Content="Pick Color">
                                <DropDownButton.Flyout>
                                    <Flyout><ColorPicker x:Name="SugSelBgColorPicker" ColorChanged="SugUI_ColorPickerChanged" IsAlphaEnabled="False"/></Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Selected Text Color" VerticalAlignment="Center"/>
                            <DropDownButton Grid.Column="1" Content="Pick Color">
                                <DropDownButton.Flyout>
                                    <Flyout><ColorPicker x:Name="SugSelTextColorPicker" ColorChanged="SugUI_ColorPickerChanged" IsAlphaEnabled="False"/></Flyout>
                                </DropDownButton.Flyout>
                            </DropDownButton>
                        </Grid>

                        <!-- Layout -->
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Font Size" VerticalAlignment="Center"/>
                            <NumberBox x:Name="SugFontSizeInput" Grid.Column="1" ValueChanged="SugUI_NumberBoxChanged" SmallChange="1" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Font Family" VerticalAlignment="Center"/>
                            <TextBox x:Name="SugFontFamilyInput" Grid.Column="1" TextChanged="SugUI_TextChanged"/>
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Item Vertical Padding" VerticalAlignment="Center"/>
                            <NumberBox x:Name="SugItemPadVInput" Grid.Column="1" ValueChanged="SugUI_NumberBoxChanged" SmallChange="1" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Item Horizontal Padding" VerticalAlignment="Center"/>
                            <NumberBox x:Name="SugItemPadHInput" Grid.Column="1" ValueChanged="SugUI_NumberBoxChanged" SmallChange="1" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="200"/></Grid.ColumnDefinitions>
                            <TextBlock Text="Window Padding" VerticalAlignment="Center"/>
                            <NumberBox x:Name="SugWinPadInput" Grid.Column="1" ValueChanged="SugUI_NumberBoxChanged" SmallChange="1" />
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- About Panel -->
                <StackPanel x:Name="AboutPanel" Spacing="20" Visibility="Collapsed">
                    <TextBlock Text="About" Style="{ThemeResource TitleTextBlockStyle}" Margin="0,0,0,20"/>
                    <TextBlock Text="Lipi IME - Open Source Transliteration Engine" Style="{ThemeResource BodyTextBlockStyle}"/>
                </StackPanel>
            </Grid>
        </NavigationView>
    </Grid>
</Window>
